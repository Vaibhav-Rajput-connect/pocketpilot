# =============================================================================
# PocketPilot Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ── Database (Neon PostgreSQL in production, local Docker in development) ─────
# For local Docker development:
DATABASE_URL=postgresql+asyncpg://pocketpilot:pocketpilot_secret_2024@db:5432/pocketpilot
DATABASE_URL_SYNC=postgresql://pocketpilot:pocketpilot_secret_2024@db:5432/pocketpilot

# Docker Compose PostgreSQL settings (only used by docker-compose.yml):
POSTGRES_USER=pocketpilot
POSTGRES_PASSWORD=pocketpilot_secret_2024
POSTGRES_DB=pocketpilot

# ── JWT Configuration ────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Backend Server ───────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=dev

# ── AI Copilot (OpenAI) ─────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
