    "/health/live": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Liveness Probe",
        "description": "Ultra-fast check just to see if the event loop is responsive.",
        "operationId": "liveness_probe_health_live_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Liveness Probe Health Live Get"
                }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "tags": [
          "System"
        ],
        "summary": "Readiness Probe",
        "description": "Deeper check to verify connections to backing services (DB, Redis).",
        "operationId": "readiness_probe_health_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Readiness Probe Health Ready Get"
                }
              }
            }
          }
        }
      }
    },
