          },
          "description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Description"
          },
          "amount": {
            "type": "number",
            "title": "Amount"
          },
          "transaction_type": {
